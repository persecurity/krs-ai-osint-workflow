# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model escalation ladder, cheapest first (comma-separated OpenRouter model IDs).
# The router starts at the first model and escalates on failure/low confidence.
OPENROUTER_MODELS=google/gemini-2.5-flash-lite,anthropic/claude-haiku-4.5,anthropic/claude-sonnet-4.5

# Optional: shown to OpenRouter for rankings/attribution
OPENROUTER_APP_TITLE=KRS-Investigator
